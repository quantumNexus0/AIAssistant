# Copy this file to backend/.env and fill in your values.
# Do NOT commit your actual credentials to version control.

# MongoDB URI for the app backend.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.1ztzusv.mongodb.net/?appName=Cluster0
DATABASE_NAME=NyayaAI

# Optional: If you need to migrate from another existing MongoDB source,
# set SOURCE_MONGO_URI and SOURCE_DATABASE_NAME.
SOURCE_MONGO_URI=mongodb+srv://<source_user>:<source_password>@cluster0.example.mongodb.net/?appName=SourceCluster
SOURCE_DATABASE_NAME=source_database
